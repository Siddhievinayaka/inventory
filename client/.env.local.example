# Environment variables for Next.js client

# MongoDB
NEXT_PUBLIC_API_URL=http://localhost:3000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/inventory-portal?retryWrites=true&w=majority

# JWT Auth
JWT_SECRET=<your_jwt_secret_key_here_min_32_chars>
NEXTAUTH_SECRET=<your_nextauth_secret_here_min_32_chars>

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=<your_cloud_name>
CLOUDINARY_API_KEY=<your_cloudinary_api_key>
CLOUDINARY_API_SECRET=<your_cloudinary_api_secret>

# OpenAI
OPENAI_API_KEY=<your_openai_api_key>

# App Settings
NEXT_PUBLIC_APP_NAME="Inventory Entry Portal"
NEXT_PUBLIC_STORE_NAME="Your Store Name"

ADMIN_EMAIL=<admin_email>
ADMIN_PASSWORD=<admin_password>
